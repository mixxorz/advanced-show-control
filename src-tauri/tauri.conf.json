{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Advanced Show Control",
  "version": "0.1.0",
  "identifier": "com.advancedshowcontrol.app",
  "build": {
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Advanced Show Control",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
